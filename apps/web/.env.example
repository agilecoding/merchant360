# ── Next.js ───────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=nextauth-secret-min-32-chars-change-in-prod

# ── Keycloak OAuth2 provider ──────────────────────────────────────────────────
# KEYCLOAK_URL: server-to-server (can be Docker internal hostname e.g. http://keycloak:8080)
KEYCLOAK_URL=http://localhost:8080
# KEYCLOAK_PUBLIC_URL: browser-facing redirect URL (must be reachable from user's machine)
# Set this when KEYCLOAK_URL is a Docker-internal hostname not reachable by the browser.
# Leave unset in local dev (falls back to KEYCLOAK_URL).
# Example for Docker Compose: KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=merchant360
KEYCLOAK_CLIENT_ID=web-client
KEYCLOAK_CLIENT_SECRET=kc-client-secret-change-in-prod

# ── GraphQL Gateway ───────────────────────────────────────────────────────────
# Internal (SSR): server-to-server
GRAPHQL_INTERNAL_URL=http://localhost:4000/graphql
# Public (browser): exposed to client
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
