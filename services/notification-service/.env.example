# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3004
LOG_LEVEL=info

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-signing-key-change-in-prod-min-32-chars
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=merchant360

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your-mailtrap-user
SMTP_PASSWORD=your-mailtrap-password
SMTP_FROM=no-reply@merchant360.dev

# ── Webhook ───────────────────────────────────────────────────────────────────
WEBHOOK_SIGNING_SECRET=whsec-change-in-prod-min-32-chars
WEBHOOK_TIMEOUT_MS=3000

# ── Retry ─────────────────────────────────────────────────────────────────────
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=500
