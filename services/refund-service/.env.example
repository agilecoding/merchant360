# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
LOG_LEVEL=info

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://admin:M3rchant_S3cr3t!@localhost:27017/merchant360?authSource=admin

# ── Auth ──────────────────────────────────────────────────────────────────────
