# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-signing-key-change-in-prod-min-32-chars
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=merchant360

# ── Subgraph URLs ─────────────────────────────────────────────────────────────
PAYMENT_SERVICE_URL=http://localhost:3001/graphql
REFUND_SERVICE_URL=http://localhost:3002/graphql
MERCHANT_SERVICE_URL=http://localhost:3003/graphql
NOTIFICATION_SERVICE_URL=http://localhost:3004/graphql

# ── Apollo ────────────────────────────────────────────────────────────────────
APOLLO_GRAPH_REF=merchant360@current
APOLLO_KEY=service:merchant360:change-in-prod
INTROSPECTION_ENABLED=true
