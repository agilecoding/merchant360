# ── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=<mongodb_password>
MONGODB_URI=mongodb://admin:<mongodb_password>@localhost:27017/merchant360?authSource=admin

# ── Auth / JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-signing-key-change-in-prod-min-32-chars

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# When running via Docker Compose:
#   KEYCLOAK_URL = Docker-internal (server→Keycloak)
#   KEYCLOAK_PUBLIC_URL = localhost (browser→Keycloak)
# When running locally (no Docker): both can be http://localhost:8080
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=merchant360
KEYCLOAK_CLIENT_ID=web-client
KEYCLOAK_CLIENT_SECRET=kc-client-secret-change-in-prod

# ── Service URLs (used by gateway and web) ────────────────────────────────────
PAYMENT_SERVICE_URL=http://localhost:3001
REFUND_SERVICE_URL=http://localhost:3002
MERCHANT_SERVICE_URL=http://localhost:3003
NOTIFICATION_SERVICE_URL=http://localhost:3004
GRAPHQL_URL=http://localhost:4000/graphql

# ── Next.js / Web ─────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=nextauth-secret-min-32-chars-change-in-prod
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
